# CareFlow Agent — LLM configuration (OPTIONAL)
#
# The app runs fully in MOCK MODE with no key set — deterministic agent outputs,
# perfect for an offline demo. To enable real LLM-backed generation, copy this
# file to `.env.local` and fill in the values below.
#
# The LLM layer (src/lib/llm.ts) speaks the OpenAI-compatible Chat Completions
# API. Point LLM_BASE_URL at any compatible provider (OpenAI, Azure OpenAI,
# Together, Groq, a local Ollama/LM Studio server, etc.) to switch providers
# without changing application code.

# Set to "true" to attempt LLM calls (falls back to mock on any error).
USE_LLM=false

# Your provider API key.
LLM_API_KEY=

# OpenAI-compatible base URL (no trailing slash). Examples:
#   OpenAI         -> https://api.openai.com/v1
#   Groq           -> https://api.groq.com/openai/v1
#   Local (Ollama) -> http://localhost:11434/v1
LLM_BASE_URL=https://api.openai.com/v1

# Model name as understood by your provider.
LLM_MODEL=gpt-4o-mini
